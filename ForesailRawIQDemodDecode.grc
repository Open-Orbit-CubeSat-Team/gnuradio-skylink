- name: epy_block_1_0
  id: epy_block
  parameters:
    _source_code: "#!/usr/bin/env python3\nimport csv\nimport json\nimport sys\nfrom\
      \ datetime import datetime, timezone\n\nimport os\nimport zlib\nimport numpy\
      \ as np\nfrom gnuradio import gr\n\nSERVICE_LABELS = {\n    (1, 7):  \"TC Verification:\
      \ Execution Completion\",\n    (3, 2):  \"OBC Housekeeping\",\n    (3, 3): \
      \ \"EPS Housekeeping\",\n    (3, 4):  \"ADCS Housekeeping\",\n    (3, 5):  \"\
      UHF Housekeeping\",\n    (3, 6):  \"Deployment Housekeeping\",\n    (4, 4):\
      \  \"Event\",\n    (6, 8):  \"File Transfer Init\",\n    (6, 13): \"File Transfer\
      \ Block\",\n}\n\nVC_LABELS = {\n    0: \"VC0\",\n    1: \"VC1\",\n    2: \"\
      VC2\",\n    3: \"Ham Repeater\",\n}\n\n\ndef safe_dt(ts: int) -> str:\n    try:\n\
      \        return datetime.fromtimestamp(ts, tz=timezone.utc).isoformat()\n  \
      \  except Exception:\n        return \"\"\n\n\ndef u32be(b: bytes, off: int)\
      \ -> int:\n    return int.from_bytes(b[off:off+4], \"big\", signed=False)\n\n\
      \ndef read_frames_from_csv(csv_path: str):\n    rows = []\n    with open(csv_path,\
      \ newline=\"\", encoding=\"utf-8\") as f:\n        reader = csv.DictReader(f)\n\
      \        for row in reader:\n            hx = (row.get(\"frame_hex\") or \"\"\
      ).strip()\n            if not hx:\n                continue\n            try:\n\
      \                frame = bytes.fromhex(hx)\n            except Exception:\n\
      \                continue\n            rows.append((row, frame))\n    return\
      \ rows\n\n\ndef find_service_marker(frame: bytes):\n    known = set(SERVICE_LABELS.keys())\n\
      \    for i in range(len(frame) - 2):\n        if frame[i] != 0x10:\n       \
      \     continue\n        st = frame[i + 1]\n        sst = frame[i + 2]\n    \
      \    if (st, sst) in known:\n            return {\n                \"marker_off\"\
      : i,\n                \"service\": st,\n                \"subtype\": sst,\n\
      \                \"payload_off\": i + 3,\n            }\n    return None\n\n\
      \ndef classify_frame(frame: bytes):\n    row = {\n        \"frame_len\": len(frame),\n\
      \        \"proto_ok\": len(frame) >= 7 and frame[:7] == b\"fOH2F1S\",\n    \
      \    \"protocol_id\": \"\",\n        \"satellite_id_ascii\": \"\",\n       \
      \ \"satellite_id_hex\": \"\",\n        \"flags_vc\": \"\",\n        \"vc\":\
      \ \"\",\n        \"vc_label\": \"\",\n        \"seq_le\": \"\",\n        \"\
      service_type\": \"\",\n        \"service_subtype\": \"\",\n        \"label\"\
      : \"\",\n        \"pus_marker_off\": \"\",\n        \"hk_unix_time\": \"\",\n\
      \        \"hk_utc\": \"\",\n        \"header_preview_hex\": frame[:24].hex(),\n\
      \        \"service_payload_hex\": \"\",\n        \"frame_hex\": frame.hex(),\n\
      \    }\n\n    if len(frame) < 11:\n        return row\n\n    proto = frame[0]\n\
      \    sat_id = frame[1:7]\n    flags_vc = frame[7]\n    vc = flags_vc & 0x07\n\
      \n    # Sequence is little-endian in these frames:\n    # 96 05 -> 1430, 97\
      \ 05 -> 1431, etc.\n    seq_le = frame[9] | (frame[10] << 8)\n\n    row[\"protocol_id\"\
      ] = f\"0x{proto:02X}\"\n    row[\"satellite_id_ascii\"] = sat_id.decode(\"ascii\"\
      , errors=\"replace\")\n    row[\"satellite_id_hex\"] = sat_id.hex()\n    row[\"\
      flags_vc\"] = f\"0x{flags_vc:02X}\"\n    row[\"vc\"] = vc\n    row[\"vc_label\"\
      ] = VC_LABELS.get(vc, f\"VC{vc}\")\n    row[\"seq_le\"] = seq_le\n\n    # Special\
      \ case: Ham repeater traffic on VC=3\n    if vc == 3:\n        row[\"label\"\
      ] = \"Ham Repeater\"\n        return row\n\n    pus = find_service_marker(frame)\n\
      \    if pus is None:\n        row[\"label\"] = row[\"vc_label\"]\n        return\
      \ row\n\n    service = pus[\"service\"]\n    subtype = pus[\"subtype\"]\n\n\
      \    row[\"service_type\"] = service\n    row[\"service_subtype\"] = subtype\n\
      \    row[\"label\"] = SERVICE_LABELS.get((service, subtype), row[\"vc_label\"\
      ])\n    row[\"pus_marker_off\"] = pus[\"marker_off\"]\n\n    payload = frame[pus[\"\
      payload_off\"]:]\n    row[\"service_payload_hex\"] = payload.hex()\n\n    #\
      \ Housekeeping timestamp begins immediately after 10 / service / subtype\n \
      \   if len(payload) >= 4:\n        ts = u32be(payload, 0)\n        if 1600000000\
      \ <= ts <= 2000000000:\n            row[\"hk_unix_time\"] = ts\n           \
      \ row[\"hk_utc\"] = safe_dt(ts)\n\n    return row\n\n\ndef write_outputs(rows,\
      \ out_base):\n    csv_path = out_base + \"_classified.csv\"\n    jsonl_path\
      \ = out_base + \"_classified.jsonl\"\n\n    fieldnames = [\n        \"index\"\
      ,\n        \"frame_len\",\n        \"proto_ok\",\n        \"protocol_id\",\n\
      \        \"satellite_id_ascii\",\n        \"satellite_id_hex\",\n        \"\
      flags_vc\",\n        \"vc\",\n        \"vc_label\",\n        \"seq_le\",\n \
      \       \"service_type\",\n        \"service_subtype\",\n        \"label\",\n\
      \        \"pus_marker_off\",\n        \"hk_unix_time\",\n        \"hk_utc\"\
      ,\n        \"header_preview_hex\",\n        \"service_payload_hex\",\n     \
      \   \"frame_hex\",\n    ]\n\n    with open(csv_path, \"w\", newline=\"\", encoding=\"\
      utf-8\") as f:\n        writer = csv.DictWriter(f, fieldnames=fieldnames)\n\
      \        writer.writeheader()\n        for row in rows:\n            writer.writerow(row)\n\
      \n    with open(jsonl_path, \"w\", encoding=\"utf-8\") as f:\n        for row\
      \ in rows:\n            f.write(json.dumps(row, sort_keys=False) + \"\\n\")\n\
      \n    return csv_path, jsonl_path\n\n\ndef main():\n    if len(sys.argv) !=\
      \ 2:\n        print(\"Usage: python3 parse_clean_frames_final.py clean_frames_parsed.csv\"\
      )\n        sys.exit(1)\n\n    in_csv = sys.argv[1]\n    frames = read_frames_from_csv(in_csv)\n\
      \n    rows = []\n    for i, (_, frame) in enumerate(frames, start=1):\n    \
      \    row = classify_frame(frame)\n        row[\"index\"] = i\n        rows.append(row)\n\
      \n    out_base = in_csv.rsplit(\".\", 1)[0]\n    csv_path, jsonl_path = write_outputs(rows,\
      \ out_base)\n\n    print(f\"Frames read    : {len(rows)}\")\n    print(f\"CSV\
      \ written    : {csv_path}\")\n    print(f\"JSONL written  : {jsonl_path}\")\n\
      \n    by_label = {}\n    by_vc = {}\n    for r in rows:\n        lbl = r[\"\
      label\"] or \"Unclassified\"\n        by_label[lbl] = by_label.get(lbl, 0) +\
      \ 1\n\n        vc_lbl = r[\"vc_label\"] or \"Unknown VC\"\n        by_vc[vc_lbl]\
      \ = by_vc.get(vc_lbl, 0) + 1\n\n    print(\"\\nCounts by VC:\")\n    for k in\
      \ sorted(by_vc):\n        print(f\"  {k}: {by_vc[k]}\")\n\n    print(\"\\nCounts\
      \ by label:\")\n    for k in sorted(by_label):\n        print(f\"  {k}: {by_label[k]}\"\
      )\n\n    print(\"\\nFirst few rows:\")\n    for r in rows[:10]:\n        print(\n\
      \            f\"idx={r['index']} \"\n            f\"seq={r['seq_le']} \"\n \
      \           f\"vc={r['vc']} ({r['vc_label']}) \"\n            f\"type={r['service_type']}/{r['service_subtype']}\
      \ \"\n            f\"label={r['label']} \"\n            f\"time={r['hk_utc']}\"\
      \n        )\n\n\nif __name__ == \"__main__\":\n    main()\n"
    affinity: ''
    alias: ''
    comment: ''
    maxoutbuf: '0'
    minoutbuf: '0'
    out_dir: '''home/groundstation-user/Documents/GNU-Radio-Flow-Graphs/Skylink'''
  states:
    _io_cache: '(''Skylink Frame Decoder'', ''blk'', [(''out_dir'', "''/tmp/skylink_out''")],
      [(''0'', ''byte'', 1)], [], ''\n    Skylink / FORESAIL-1 frame decoder\n\n    Input  :
      unpacked bits (uint8, one bit per byte, MSB-first)\n    Output : none  (frames
      written to <out_dir>/clean_frames.bin)\n\n    Framing: ASM (0x1ACFFC1D, 32 bits)\n           +
      Golay(24,12) length field\n           + RS(255,223) CCSDS-whitened codeword\n\n    Output
      file is self-delimiting: each frame prefixed with 2-byte big-endian length.\n    '',
      [''out_dir''])'
    bus_sink: false
    bus_source: false
    bus_structure: null
    coordinate: [1072, 360.0]
    rotation: 0
    state: disabled
